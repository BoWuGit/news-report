{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://news-report.local/schemas/source.schema.json",
  "title": "News Report Source",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "url",
    "category",
    "interface_types",
    "content_types",
    "open_source",
    "agent_friendly",
    "stage",
    "pricing",
    "summary",
    "last_verified"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "url": {
      "type": "string",
      "format": "uri"
    },
    "category": {
      "type": "string",
      "enum": ["saas_source_service", "agent_tool", "processing_tool", "source_registry"]
    },
    "interface_types": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["rss", "api", "cli", "mcp", "skills", "web", "email"]
      }
    },
    "content_types": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "open_source": {
      "type": "boolean"
    },
    "agent_friendly": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "stage": {
      "type": "string",
      "enum": ["active", "beta", "deprecated", "unknown"]
    },
    "pricing": {
      "type": "string",
      "enum": ["free", "paid", "mixed", "unknown"]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "last_verified": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    }
  }
}
