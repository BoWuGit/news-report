{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://news-report.local/schemas/briefing-request.schema.json",
  "title": "Briefing Request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "topics",
    "sources",
    "language",
    "max_items",
    "summary_style",
    "user_profile"
  ],
  "properties": {
    "topics": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "language": {
      "type": "string",
      "minLength": 2
    },
    "max_items": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100
    },
    "summary_style": {
      "type": "string",
      "enum": ["headline_only", "concise", "detailed"]
    },
    "user_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "explicit_preferences",
        "blocked_topics",
        "time_decay_days",
        "diversity_floor"
      ],
      "properties": {
        "explicit_preferences": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "blocked_topics": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "time_decay_days": {
          "type": "integer",
          "minimum": 1,
          "maximum": 365
        },
        "diversity_floor": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    }
  }
}
